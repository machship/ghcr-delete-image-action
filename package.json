{
  "name": "ghcr-delete-image-action",
  "version": "1.0.1",
  "description": "JavaScript Action Template",
  "main": "index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run lint && npm run prepare && npm run test",
    "release": "release-it --no-npm.publish --github.release --npm.ignoreVersion --git.tagName='v${version}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/machship/ghcr-delete-image-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/machship/ghcr-delete-image-action/issues"
  },
  "homepage": "https://github.com/machship/ghcr-delete-image-action#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "release-it": "^17.10.0"
  }
}
